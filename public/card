<!DOCTYPE html>
<html lang="en">

<head>
    <title>Learn</title>
    <meta charset="utf-8">
    <link rel="icon" href="img/favicon.ico" type="image/png">
    <link rel="stylesheet" type="text/css" href="card_assets/styles.css" />
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <script src="card_assets/data.js" type="text/javascript"></script>
    <script src="card_assets/draw.js" type="text/javascript"></script>
    <script src="card_assets/card.js" type="text/javascript"></script>
    <script type="text/javascript" src="card_assets/content_selector.js"></script>
</head>

<body onload="addListener(); changeLetter();">
    <div class="top-row">
        <div class="column">
            <label>Select Learning Items - </label>
            <input type = "checkbox" id="comparison" onclick="changeContent();">Comparison</input>
            <input type = "checkbox" id="beforeAfter" onclick="changeContent();">Before After</input>
            <input type = "checkbox" id="plus" onclick="changeContent();">Plus</input>
            <input type = "checkbox" id="minus" onclick="changeContent();">Minus</input>
            <input type = "checkbox" id="bn-alpha" onclick="changeContent();">Bengali Alphabets</input>
            <input type = "checkbox" id="hi-alpha" onclick="changeContent();">Hindi Alphabets</input>
            <input type = "checkbox" id="shapes" onclick="changeContent();">Shapes</input>
            <input type = "checkbox" id="colors" onclick="changeContent();">Colors</input>
            <input type = "checkbox" id="all" onclick="changeContent();">All</input>
        </div>
    </div>
    <div id="contentRow" class="row">
        <div class="column">
            <div class="scene scene--card">
                <div class="card">
                    <div id="front" class="">front</div>
                    <div id="back" class="card__face card__face--back">back</div>
                </div>
                <button id="refresh" onclick="changeLetter();">&#x21bb;</button>
            </div>
        </div>
    </div>
</body>

</html>