<!DOCTYPE html>
<html lang="en">

<head>
    <title>CSS Website Layout</title>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <style>
        * {
            box-sizing: border-box;
        }

        body {
            margin: 0;
        }

        /* Create three equal columns that floats next to each other */
        .column {
            float: left;
            text-align: center;
            vertical-align: middle;
            width: 99vw;
            padding: 15px;
        }
        .row{
            height: 40vh;
        }

        /* Clear floats after the columns */
        .row:after {
            content: "";
            display: table;
            clear: both;
        }

        .textBlue {
            font-size: 30vh;
            text-shadow: 10px 10px 10px slateblue;
            color: blue;
        }

        .textGreen {
            font-size: 30vh;
            text-shadow: 10px 10px 10px lightgreen;
            color: darkgreen;
        }

        .textRed {
            font-size: 30vh;
            text-shadow: 10px 10px 10px lightcoral;
            color: darkred;
        }

        .textSlate {
            font-size: 30vh;
            text-shadow: 10px 10px 10px slategray;
            color: teal;
        }

        .textBrown {
            font-size: 30vh;
            text-shadow: 10px 10px 10px hotpink;
            color: indigo;
        }

        .textMaroon {
            font-size: 30vh;
            text-shadow: 10px 10px 10px goldenrod;
            color: maroon;
        }

        /* Responsive layout - makes the three columns stack on top of each other instead of next to each other */
        @media screen and (max-width:98vw) {
            .column {
                width: 100vw;
            }
        }
    </style>
    <script>

        function changeLetter(){
            var styles=["textBlue", "textGreen", "textRed", "textSlate", "textBrown", "textMaroon"];
            var letters = ["&#X0905;", "&#X0906;", "&#X0907;", "&#X0908;", "&#X0990;", "&#X0995;","&#X0996;","&#X0997;","&#X0998;", "&#X0041;", ];
            
            var letterIndex = parseInt(letters.length * Math.random()); 
            var styleIndex =  parseInt(styles.length * Math.random()); 
            
            document.getElementById("content").innerHTML=letters[letterIndex];
            document.getElementById("content").setAttribute("class", styles[styleIndex]);
        }
    </script>
</head>

<body onload="changeLetter()" onclick="changeLetter();">
    <div class="row">
        <div class="column">
            <p id="content"></p>
        </div>
    </div>
</body>
</html>